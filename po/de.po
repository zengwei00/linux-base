msgid "kernel-img.conf - configuration file for Linux kernel packages"
msgstr "kernel-img.conf - Konfigurationsdatei für Linux-Kernel-Image-Pakete"

#. type: SH
#: man/kernel-img.conf.5:30
#, no-wrap
msgid "SYNOPSIS"
